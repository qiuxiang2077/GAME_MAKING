            <!-- Sleep Stage Gameplay -->
            <div class="mt-12 glass rounded-2xl p-8">
                <h3 class="font-serif text-2xl font-bold mb-6" style="color: #B8B0A8;">睡眠阶段玩法</h3>
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="glass rounded-xl p-6">
