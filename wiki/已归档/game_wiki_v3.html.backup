            <!-- Color Palette -->
            <div class="glass rounded-2xl p-8 mb-12">
                <h3 class="font-serif text-2xl font-bold mb-6" style="color: #B8B0A8;">色彩规范</h3>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
