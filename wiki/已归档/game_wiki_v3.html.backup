            <!-- Scene Concepts -->
            <div class="grid md:grid-cols-2 gap-8">
                <div class="glass rounded-xl overflow-hidden card-hover">
                    <div class="h-48 flex items-center justify-center" style="background: linear-gradient(135deg, rgba(107, 123, 140, 0.2), rgba(90, 107, 92, 0.2));">
                        <i class="fas fa-store text-6xl" style="color: rgba(107, 123, 140, 0.4);"></i>
                    </div>
                    <div class="p-6">
                        <h4 class="font-bold text-xl mb-2" style="color: #B8B0A8;">废弃商场</h4>
                        <p class="text-sm mb-4" style="color: #7A7570;">
                            玻璃天幕长满苔藓，悬挂的装饰球褪色斑驳，胶囊电梯停止运转
