            <!-- Emotional Projection Table -->
            <div class="mt-12 glass rounded-2xl p-8">
                <h3 class="font-serif text-2xl font-bold mb-6" style="color: #B8B0A8;">情绪投射类型</h3>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr style="border-bottom: 1px solid rgba(184, 176, 168, 0.1);">
                                <th class="pb-4 font-medium" style="color: #7A7570;">情绪类型</th>
                                <th class="pb-4 font-medium" style="color: #7A7570;">投射表现</th>
                                <th class="pb-4 font-medium" style="color: #7A7570;">典型形态</th>
                            </tr>
                        </thead>
                        <tbody style="color: #9A9085;">
                            <tr style="border-bottom: 1px solid rgba(184, 176, 168, 0.05);">
                                <td class="py-4"><span class="tag" style="background: rgba(107, 74, 60, 0.2); color: #8B6A5C;">恐惧</span></td>
                                <td class="py-4">威胁性实体</td>
                                <td class="py-4">追逐型敌人</td>
                            </tr>
                            <tr style="border-bottom: 1px solid rgba(184, 176, 168, 0.05);">
                                <td class="py-4"><span class="tag" style="background: rgba(107, 123, 140, 0.2); color: #7A8A9A;">孤独</span></td>
                                <td class="py-4">虚空、缺失</td>
                                <td class="py-4">潜伏型敌人</td>
                            </tr>
                            <tr style="border-bottom: 1px solid rgba(184, 176, 168, 0.05);">
                                <td class="py-4"><span class="tag" style="background: rgba(154, 144, 133, 0.2); color: #9A9085;">焦虑</span></td>
                                <td class="py-4">压迫感</td>
                                <td class="py-4">巡逻型敌人</td>
                            </tr>
                            <tr style="border-bottom: 1px solid rgba(184, 176, 168, 0.05);">
                                <td class="py-4"><span class="tag" style="background: rgba(160, 144, 112, 0.2); color: #9A8A6A;">愤怒</span></td>
                                <td class="py-4">破坏性力量</td>
                                <td class="py-4">狂暴敌人</td>
                            </tr>
                            <tr>
                                <td class="py-4"><span class="tag" style="background: rgba(90, 80, 95, 0.2); color: #8A7A8A;">悲伤</span></td>
                                <td class="py-4">沉重、缓慢</td>
                                <td class="py-4">沼泽、锁链</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Medical Elements Design -->
            <div class="mt-12 glass rounded-2xl p-8">
                <h3 class="font-serif text-2xl font-bold mb-6" style="color: #B8B0A8;">医学元素设计</h3>
                <div class="grid md:grid-cols-3 gap-4">
                    <div class="glass rounded-lg p-4">
                        <h4 class="font-bold mb-2" style="color: #B8B0A8;">疾病 → 异常状态</h4>
                        <p class="text-sm" style="color: #9A9085;">现实中的健康问题在梦境中表现为异常状态，影响游戏机制</p>
                    </div>
                    <div class="glass rounded-lg p-4">
                        <h4 class="font-bold mb-2" style="color: #B8B0A8;">病原 → 怪物</h4>
                        <p class="text-sm" style="color: #9A9085;">负面情绪和健康问题的根源在梦境中具象化为怪物</p>
                    </div>
                    <div class="glass rounded-lg p-4">
                        <h4 class="font-bold mb-2" style="color: #B8B0A8;">心理 → 技能</h4>
                        <p class="text-sm" style="color: #9A9085;">心理状态和情绪管理转化为游戏中的技能和能力</p>
                    </div>
                </div>
            </div>

            <!-- Special Sleep States -->
            <div class="mt-12 glass rounded-2xl p-8">
                <h3 class="font-serif text-2xl font-bold mb-6" style="color: #B8B0A8;">特殊睡眠状态</h3>
                <div class="grid md:grid-cols-3 gap-4">
                    <div class="glass rounded-lg p-4">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center mb-3" style="background: rgba(107, 123, 140, 0.2);">
                            <i class="fas fa-dream text-millennium-blue"></i>
                        </div>
                        <h4 class="font-bold mb-2" style="color: #B8B0A8;">梦中梦</h4>
                        <p class="text-sm" style="color: #9A9085;">在梦境中再次入睡，进入更深层的梦境世界</p>
                    </div>
                    <div class="glass rounded-lg p-4">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center mb-3" style="background: rgba(160, 144, 112, 0.2);">
                            <i class="fas fa-lightbulb text-millennium-gold"></i>
                        </div>
                        <h4 class="font-bold mb-2" style="color: #B8B0A8;">清醒梦</h4>
                        <p class="text-sm" style="color: #9A9085;">意识到自己在做梦，获得对梦境的部分控制权</p>
                    </div>
                    <div class="glass rounded-lg p-4">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center mb-3" style="background: rgba(107, 74, 60, 0.2);">
                            <i class="fas fa-weight-hanging text-millennium-rust"></i>
                        </div>
                        <h4 class="font-bold mb-2" style="color: #B8B0A8;">鬼压床</h4>
                        <p class="text-sm" style="color: #9A9085;">身体无法移动，面对恐惧实体的特殊挑战</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="section-divider max-w-4xl mx-auto"></div>

    <!-- Art Style Section -->
    <section id="art" class="py-24 px-6">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <span class="tag glass text-millennium-rust mb-4">ART STYLE</span>
