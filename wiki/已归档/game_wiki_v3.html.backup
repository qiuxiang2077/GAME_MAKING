                                <i class="fas fa-check-circle text-millennium-rust mt-1"></i>
                                <span>恐惧管理</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <i class="fas fa-check-circle text-millennium-rust mt-1"></i>
                                <span>资源收集</span>
                            </li>
                        </ul>
                    </div>
                    <div class="glass rounded-xl p-6">
                        <h4 class="font-bold text-lg mb-3 text-millennium-gold">REM期</h4>
