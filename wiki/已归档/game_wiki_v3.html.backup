                <div class="glass rounded-xl overflow-hidden card-hover">
                    <div class="h-48 flex items-center justify-center" style="background: linear-gradient(135deg, rgba(107, 74, 60, 0.2), rgba(160, 144, 112, 0.2));">
                        <i class="fas fa-school text-6xl" style="color: rgba(107, 74, 60, 0.4);"></i>
                    </div>
