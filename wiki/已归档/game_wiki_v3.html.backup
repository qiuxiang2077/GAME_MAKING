    <section id="gameplay" class="py-24 px-6">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <span class="tag glass text-millennium-gold mb-4">GAMEPLAY</span>
                <h2 class="font-serif text-4xl md:text-5xl font-bold mb-4" style="color: #B8B0A8;">游戏机制</h2>
                <p class="max-w-2xl mx-auto" style="color: #8A8580;">
                    梦境不仅是背景，更是核心游戏机制
                </p>
            </div>

            <!-- Sleep Cycle -->
            <div class="glass rounded-2xl p-8 mb-12">
                <h3 class="font-serif text-2xl font-bold mb-6 text-center" style="color: #B8B0A8;">睡眠周期循环</h3>
                <div class="mermaid">
graph LR
    A[清醒期<br/>5分钟] --> B[浅睡期<br/>10分钟]
    B --> C[深睡期<br/>10分钟]
    C --> D[快速眼动期<br/>15分钟]
    D --> E{继续?}
    E -->|是| A
    E -->|否| F[醒来]
    
    style A fill:#6B7B8C,stroke:#6B7B8C,color:#fff
    style B fill:#5A6B5C,stroke:#5A6B5C,color:#fff
    style C fill:#6B4A3C,stroke:#6B4A3C,color:#fff
    style D fill:#A09070,stroke:#A09070,color:#fff
    style F fill:#7A6B7C,stroke:#7A6B7C,color:#fff
                </div>
            </div>

            <!-- Game Mechanics Grid -->
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="glass rounded-xl p-6 card-hover">
                    <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4 bg-millennium-blue">
                        <i class="fas fa-route text-millennium-blue text-xl"></i>
                    </div>
                    <h4 class="font-bold text-lg mb-2" style="color: #B8B0A8;">路线选择</h4>
