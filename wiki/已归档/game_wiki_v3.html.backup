                                <i class="fas fa-check-circle text-millennium-teal mt-1"></i>
                                <span>简单解谜</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <i class="fas fa-check-circle text-millennium-teal mt-1"></i>
                                <span>躲避巡逻型敌人</span>
                            </li>
                        </ul>
